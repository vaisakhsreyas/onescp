#!/bin/bash

show_help() {
    echo "onescp - Simple SCP wrapper"
    echo ""
    echo "Usage:"
    echo "  onescp upload <local_path> <server|inventory_file> <remote_path>"
    echo "  onescp download <server|inventory_file> <remote_path> <local_path>"
    echo ""
    echo "Examples:"
    echo "  onescp upload file.txt 192.168.1.20 /tmp/"
    echo "  onescp upload mydir servers.inv /tmp/"
    echo "  onescp download servers.inv /tmp/file.txt ./"
}

if [ $# -eq 0 ]; then
    show_help
    exit 1
fi

ACTION=$1

run_scp() {
    scp -r "$@"
    if [ $? -eq 0 ]; then
        echo "✅ Success!"
    else
        echo "❌ Failed!"
    fi
}

process_target() {
    local source=$1
    local target=$2
    local remote_path=$3
    local local_path=$4

    if [[ $target == *.inv ]]; then
        while IFS= read -r server; do
            [ -z "$server" ] && continue
            if [ "$ACTION" = "upload" ]; then
                run_scp "$source" "$server:$remote_path"
            else
                run_scp "$server:$remote_path" "$local_path"
            fi
        done < "$target"
    else
        if [ "$ACTION" = "upload" ]; then
            run_scp "$source" "$target:$remote_path"
        else
            run_scp "$target:$remote_path" "$local_path"
        fi
    fi
}

case $ACTION in

upload)
    if [ $# -ne 4 ]; then
        show_help
        exit 1
    fi
    process_target "$2" "$3" "$4" ""
    ;;

download)
    if [ $# -ne 4 ]; then
        show_help
        exit 1
    fi
    process_target "" "$2" "$3" "$4"
    ;;

*)
    show_help
    ;;
esac

