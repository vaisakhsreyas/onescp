#!/bin/bash

show_help() {
    echo "onescp - Simple SCP wrapper"
    echo ""
    echo "Usage:"
    echo "  onescp upload <local_path> <server> <remote_path>"
    echo "  onescp download <server> <remote_path> <local_path>"
    echo ""
    echo "Examples:"
    echo "  onescp upload file.txt 192.168.1.20 /tmp/"
    echo "  onescp upload mydir 192.168.1.20 /tmp/"
    echo "  onescp download 192.168.1.20 /tmp/file.txt ./"
    echo "  onescp download 192.168.1.20 /tmp/mydir ./"
}

if [ $# -eq 0 ]; then
    show_help
    exit 1
fi

ACTION=$1

run_scp() {
    scp -r "$@"
    if [ $? -eq 0 ]; then
        echo "✅ Success!"
    else
        echo "❌ Failed!"
    fi
}

case $ACTION in

upload)
    if [ $# -ne 4 ]; then
        show_help
        exit 1
    fi
    run_scp "$2" "$3:$4"
    ;;

download)
    if [ $# -ne 4 ]; then
        show_help
        exit 1
    fi
    run_scp "$2:$3" "$4"
    ;;

*)
    show_help
    ;;
esac
